<Window x:Class="RemoteCapture.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RemoteCapture"
        mc:Ignorable="d"
        Title="Remote Capture - WebRTC Sender/Receiver" Height="600" Width="900"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid x:Name="ControlsGrid" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Margin="10">
                <!-- モード選択 -->
                <GroupBox Header="Mode" Margin="10">
                    <StackPanel>
                        <RadioButton x:Name="SenderModeRadio" Content="Sender (Capture &amp; Send)" IsChecked="True" Margin="5" Checked="ModeRadio_Checked" />
                        <RadioButton x:Name="ReceiverModeRadio" Content="Receiver (Receive &amp; Display)" Margin="5" Checked="ModeRadio_Checked" />
                    </StackPanel>
                </GroupBox>

                <!-- 送信モード用コントロール -->
                <StackPanel x:Name="SenderControls">
                    <!-- primary monitor -->
                    <Button x:Name="PrimaryMonitorButton" Content="Use Primary Monitor" Click="PrimaryMonitorButton_Click" Margin="10" />

                    <!-- monitor select -->
                    <ComboBox x:Name="MonitorComboBox" Margin="10" SelectionChanged="MonitorComboBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DeviceName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                <!-- フレームレート設定 -->
                <GroupBox Header="Frame Rate Control" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Target FPS:" Margin="5,5,5,0" />
                        <ComboBox x:Name="FrameRateComboBox" Margin="5" SelectionChanged="FrameRateComboBox_SelectionChanged">
                            <ComboBoxItem Content="Unlimited (60+ FPS)" Tag="0" IsSelected="True" />
                            <ComboBoxItem Content="30 FPS" Tag="30" />
                            <ComboBoxItem Content="24 FPS" Tag="24" />
                            <ComboBoxItem Content="15 FPS" Tag="15" />
                            <ComboBoxItem Content="10 FPS" Tag="10" />
                            <ComboBoxItem Content="5 FPS" Tag="5" />
                            <ComboBoxItem Content="1 FPS" Tag="1" />
                        </ComboBox>
                        <CheckBox x:Name="EnablePreviewCheckBox" 
                                  Content="Enable Preview" 
                                  IsChecked="False" 
                                  Margin="5" 
                                  Checked="EnablePreviewCheckBox_Changed" 
                                  Unchecked="EnablePreviewCheckBox_Changed" />
                    </StackPanel>
                </GroupBox>

                <!-- フレームデータ情報表示 -->
                <GroupBox Header="Frame Data Info" Margin="10">
                    <StackPanel>
                        <TextBlock x:Name="ResolutionText" Text="Resolution: -" Margin="5" />
                        <TextBlock x:Name="DataSizeText" Text="Data Size: -" Margin="5" />
                        <TextBlock x:Name="FpsText" Text="FPS: -" Margin="5" />
                        <TextBlock x:Name="LastUpdateText" Text="Last Update: -" Margin="5" TextWrapping="Wrap" />
                    </StackPanel>
                </GroupBox>

                <!-- WebRTC送信接続 -->
                <GroupBox Header="WebRTC Connection" Margin="10">
                    <StackPanel>
                        <Button x:Name="CreateOfferButton" Content="Create Offer (SDP)" Click="CreateOfferButton_Click" Margin="5" />
                        <TextBlock x:Name="ConnectionStatusText" Text="Status: Disconnected" Margin="5" TextWrapping="Wrap" FontWeight="Bold" />
                    </StackPanel>
                </GroupBox>
                </StackPanel>

                <!-- 受信モード用コントロール -->
                <StackPanel x:Name="ReceiverControls" Visibility="Collapsed">
                    <!-- WebRTC受信接続 -->
                    <GroupBox Header="WebRTC Receiver" Margin="10">
                        <StackPanel>
                            <TextBlock Text="Paste Offer SDP from sender:" Margin="5" FontWeight="Bold" />
                            <TextBox x:Name="ReceiverOfferSdpTextBox" 
                                     Height="120" 
                                     TextWrapping="Wrap" 
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" 
                                     Margin="5" 
                                     FontFamily="Consolas"
                                     FontSize="9" />
                            <Button x:Name="SetOfferButton" Content="Set Offer &amp; Create Answer" Click="SetOfferButton_Click" Margin="5" />
                            <TextBlock x:Name="ReceiverConnectionStatusText" Text="Status: Disconnected" Margin="5" TextWrapping="Wrap" FontWeight="Bold" />
                        </StackPanel>
                    </GroupBox>

                    <!-- 受信映像情報 -->
                    <GroupBox Header="Received Video Info" Margin="10">
                        <StackPanel>
                            <TextBlock x:Name="ReceivedResolutionText" Text="Resolution: -" Margin="5" />
                            <TextBlock x:Name="ReceivedFpsText" Text="FPS: -" Margin="5" />
                            <TextBlock x:Name="ReceivedLastUpdateText" Text="Last Update: -" Margin="5" TextWrapping="Wrap" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </StackPanel>
            <Button x:Name="StopButton" Grid.Row="1" Content="Stop" Click="StopButton_Click" Margin="10" />
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="220" />
            </Grid.RowDefinitions>

            <!-- キャプチャ/受信プレビュー -->
            <Grid Grid.Row="0">
                <!-- 送信モード：Compositionで表示（BasicSampleApplicationが管理） -->
                <Rectangle x:Name="SenderPreviewArea" Fill="WhiteSmoke" />

                <!-- 受信モード：Image コントロールで表示 -->
                <Image x:Name="ReceiverVideoImage" 
                       Visibility="Collapsed" 
                       Stretch="Uniform" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" />

                <!-- 受信待機中メッセージ -->
                <TextBlock x:Name="ReceiverWaitingMessage"
                           Text="Waiting for video stream..."
                           Visibility="Collapsed"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="Gray" />
            </Grid>

            <!-- SDP交換エリア（送信モード） -->
            <Grid x:Name="SenderSdpArea" Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Local SDP (Offer):" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBox Grid.Row="1" x:Name="LocalSdpTextBox" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" 
                         IsReadOnly="True" 
                         Margin="0,0,0,10" 
                         FontFamily="Consolas"
                         FontSize="10" />

                <TextBlock Grid.Row="2" Text="Remote SDP (Answer from receiver):" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBox Grid.Row="3" x:Name="RemoteSdpTextBox" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" 
                         Margin="0,0,0,5" 
                         FontFamily="Consolas"
                         FontSize="10" />

                <Button Grid.Row="4" x:Name="SetAnswerButton" Content="Set Remote Answer" Click="SetAnswerButton_Click" Padding="10,5" />
            </Grid>

            <!-- SDP交換エリア（受信モード） -->
            <Grid x:Name="ReceiverSdpArea" Grid.Row="1" Margin="10" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Local SDP (Answer - Send this to sender):" FontWeight="Bold" Margin="0,0,0,5" />
                <TextBox Grid.Row="1" x:Name="ReceiverLocalSdpTextBox" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" 
                         IsReadOnly="True" 
                         Margin="0" 
                         FontFamily="Consolas"
                         FontSize="10" />
            </Grid>
        </Grid>
    </Grid>
</Window>
