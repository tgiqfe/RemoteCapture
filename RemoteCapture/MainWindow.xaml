<Window x:Class="RemoteCapture.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RemoteCapture"
        mc:Ignorable="d"
        Title="Remote Capture - WebSocket Screen Sharing" Height="800" Width="1000"
        Loaded="Window_Loaded">
    <Grid>
        <TabControl x:Name="MainTabControl">
            <!-- Sender Tab -->
            <TabItem Header="送信側 (Sender)">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="ControlsGrid" Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="10">
                            <TextBlock Text="画面キャプチャ設定" FontWeight="Bold" Margin="5" />
                            <Button x:Name="PrimaryMonitorButton" Content="プライマリモニター使用" Click="PrimaryMonitorButton_Click" Margin="5" />
                            <ComboBox x:Name="MonitorComboBox" Margin="5" SelectionChanged="MonitorComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DeviceName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Separator Margin="5,15,5,15" />

                            <TextBlock Text="WebSocket送信設定" FontWeight="Bold" Margin="5" />

                            <TextBlock Text="圧縮形式:" Margin="5,10,5,5" />
                            <StackPanel Margin="5,0,5,0">
                                <RadioButton x:Name="PngRadioButton" Content="PNG (高画質・大容量)" IsChecked="True" 
                                             GroupName="CompressionFormat" Checked="CompressionFormat_Changed" />
                                <RadioButton x:Name="JpegRadioButton" Content="JPEG (圧縮・小容量)" 
                                             GroupName="CompressionFormat" Checked="CompressionFormat_Changed" />
                            </StackPanel>

                            <TextBlock x:Name="JpegQualityLabel" Text="JPEG品質:" Margin="5,10,5,5" IsEnabled="False" />
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <Slider x:Name="JpegQualitySlider" Minimum="10" Maximum="100" Value="75" Width="120" 
                                        ValueChanged="JpegQualitySlider_ValueChanged" TickFrequency="5" IsSnapToTickEnabled="True" 
                                        IsEnabled="False" />
                                <TextBlock x:Name="JpegQualityValueText" Text="75" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Text="送信FPS:" Margin="5,10,5,5" />
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <Slider x:Name="FpsSlider" Minimum="1" Maximum="60" Value="30" Width="120" 
                                        ValueChanged="FpsSlider_ValueChanged" TickFrequency="1" IsSnapToTickEnabled="True" />
                                <TextBlock x:Name="FpsValueText" Text="30" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>

                            <Button x:Name="StartServerButton" Content="サーバー開始" Click="StartServerButton_Click" Margin="5,10,5,5" Background="LightGreen" />
                            <Button x:Name="StopServerButton" Content="サーバー停止" Click="StopServerButton_Click" Margin="5" Background="LightCoral" IsEnabled="False" />

                            <TextBlock Text="接続状態:" FontWeight="Bold" Margin="5,15,5,5" />
                            <TextBlock x:Name="ServerStatusText" Text="停止中" Margin="5" />
                            <TextBlock Text="サーバーアドレス:" FontWeight="Bold" Margin="5,10,5,5" />
                            <TextBlock x:Name="ServerAddressDisplay" Text="-" Margin="5" TextWrapping="Wrap" Foreground="Blue" />
                            <TextBlock x:Name="ConnectedClientsText" Text="接続クライアント数: 0 / 4" Margin="5" />
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                            <Button x:Name="SnapshotButton" Content="スナップショット保存" Click="SnapshotButton_Click" Margin="10" />
                            <Button x:Name="StopButton" Content="キャプチャ停止" Click="StopButton_Click" Margin="10" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Rectangle Fill="WhiteSmoke" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Receiver Tab -->
            <TabItem Header="受信側 (Receiver)">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="10">
                        <TextBlock Text="WebSocket受信設定" FontWeight="Bold" Margin="5" />
                        <TextBlock Text="サーバーアドレス:" Margin="5,10,5,5" />
                        <TextBox x:Name="ServerAddressTextBox" Text="ws://localhost:8080/" Margin="5" />

                        <Button x:Name="ConnectButton" Content="接続" Click="ConnectButton_Click" Margin="5,10,5,5" Background="LightGreen" />
                        <Button x:Name="DisconnectButton" Content="切断" Click="DisconnectButton_Click" Margin="5" Background="LightCoral" IsEnabled="False" />

                        <TextBlock Text="接続状態:" FontWeight="Bold" Margin="5,15,5,5" />
                        <TextBlock x:Name="ClientStatusText" Text="未接続" Margin="5" />
                        <TextBlock x:Name="ReceivedFramesText" Text="受信フレーム数: 0" Margin="5" />
                    </StackPanel>

                    <Grid Grid.Column="1" Background="Black">
                        <Image x:Name="ReceivedImage" Stretch="Uniform" />
                        <TextBlock x:Name="NoImageText" Text="受信待機中..." 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   Foreground="White" FontSize="20" />
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
