<Window x:Class="RemoteCapture.Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RemoteCapture.Viewer"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="1000"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="ws://"
                       VerticalAlignment="Center"
                       Margin="10,0,3,0"
                       FontFamily="Noto Sans JP" FontSize="16" />
            <TextBox Name="TextBox_IPAddress" Margin="3" Width="200"
                     Padding="3"
                     FontFamily="Noto Sans JP" FontSize="16" />
            <TextBlock Text=":"
                       VerticalAlignment="Center"
                       Margin="3,0,3,0"
                       FontFamily="Noto Sans JP" FontSize="16" />
            <TextBox Name="TextBox_PortNumber" Margin="3" Width="60"
                     Padding="3"
                     FontFamily="Noto Sans JP" FontSize="16" />
            <TextBlock Text="/screen"
                       VerticalAlignment="Center"
                       Margin="3,0,10,0"
                       FontFamily="Noto Sans JP" FontSize="16" />
            <Button Name="Button_Connect" Content="Connect" Margin="3" Width="80"
                    Click="Button_Connect_Click"
                    FontFamily="Noto Sans JP" FontSize="14" />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1"
                Margin="5" Padding="3">
            <Image Grid.Row="1" x:Name="ScreenImage" Stretch="Uniform" />
        </Border>
    </Grid>
</Window>
